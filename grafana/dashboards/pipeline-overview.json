{
  "title": "Trypto Collector Pipeline",
  "uid": "trypto-collector-pipeline",
  "timezone": "browser",
  "refresh": "5s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "panels": [
    {
      "id": 100,
      "title": "📡 Throughput",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 1,
      "title": "거래소별 발행 rate (msg/sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "maxDataPoints": 2880,
      "targets": [
        {
          "expr": "rate(rabbitmq_publish_total[1m])",
          "legendFormat": "{{exchange}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "msg/s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "pointSize": 5,
            "showPoints": "auto"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 2,
      "title": "전체 합산 발행 rate (msg/sec)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "maxDataPoints": 2880,
      "targets": [
        {
          "expr": "sum(rate(rabbitmq_publish_total[1m]))",
          "legendFormat": "total"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "msg/s",
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 20
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 3,
      "title": "거래소별 누적 발행 수",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rabbitmq_publish_total",
          "legendFormat": "{{exchange}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 17,
      "title": "거래소별 Throughput 통계",
      "type": "table",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "avg_over_time(rate(rabbitmq_publish_total[1m])[$__range:1m])",
          "format": "table",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "quantile_over_time(0.5, rate(rabbitmq_publish_total[1m])[$__range:1m])",
          "format": "table",
          "instant": true
        },
        {
          "refId": "C",
          "expr": "max_over_time(rate(rabbitmq_publish_total[1m])[$__range:1m])",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "instance": true,
              "job": true
            },
            "indexByName": {
              "exchange": 0,
              "Value #A": 1,
              "Value #B": 2,
              "Value #C": 3
            },
            "renameByName": {
              "exchange": "Exchange",
              "Value #A": "mean",
              "Value #B": "median",
              "Value #C": "max"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "msg/s",
          "decimals": 1
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Exchange" },
            "properties": [
              { "id": "unit", "value": "string" },
              { "id": "custom.width", "value": 120 }
            ]
          }
        ]
      }
    },
    {
      "id": 18,
      "title": "전체 Throughput 통계",
      "type": "table",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "avg_over_time(sum(rate(rabbitmq_publish_total[1m]))[$__range:1m])",
          "format": "table",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "quantile_over_time(0.5, sum(rate(rabbitmq_publish_total[1m]))[$__range:1m])",
          "format": "table",
          "instant": true
        },
        {
          "refId": "C",
          "expr": "max_over_time(sum(rate(rabbitmq_publish_total[1m]))[$__range:1m])",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "instance": true,
              "job": true
            },
            "indexByName": {
              "Value #A": 0,
              "Value #B": 1,
              "Value #C": 2
            },
            "renameByName": {
              "Value #A": "mean",
              "Value #B": "median",
              "Value #C": "max"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "msg/s",
          "decimals": 1
        }
      }
    },
    {
      "id": 200,
      "title": "⏱ Latency",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 15 }
    },
    {
      "id": 4,
      "title": "파이프라인 처리 시간",
      "description": "WebSocket 수신 후 Redis 저장 + RabbitMQ 발행 완료까지 소요 시간",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(ticker_latency_seconds_sum[1m]) / rate(ticker_latency_seconds_count[1m])",
          "legendFormat": "{{exchange}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 6,
      "title": "Redis 쓰기 시간",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(redis_write_time_seconds_sum[1m]) / rate(redis_write_time_seconds_count[1m])",
          "legendFormat": "mean"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 14,
      "title": "파이프라인 처리 시간 통계",
      "type": "table",
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by(exchange) (rate(ticker_latency_seconds_sum[1m])) / sum by(exchange) (rate(ticker_latency_seconds_count[1m]))",
          "format": "table",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "max by(exchange) (ticker_latency_seconds_max)",
          "format": "table",
          "instant": true
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.95, sum by(exchange, le) (rate(ticker_latency_seconds_bucket[1m])))",
          "format": "table",
          "instant": true
        },
        {
          "refId": "D",
          "expr": "histogram_quantile(0.99, sum by(exchange, le) (rate(ticker_latency_seconds_bucket[1m])))",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {
              "exchange": 0,
              "Value #A": 1,
              "Value #B": 2,
              "Value #C": 3,
              "Value #D": 4
            },
            "renameByName": {
              "exchange": "Exchange",
              "Value #A": "mean",
              "Value #B": "max",
              "Value #C": "p95",
              "Value #D": "p99"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 4
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Exchange" },
            "properties": [
              { "id": "unit", "value": "string" },
              { "id": "custom.width", "value": 120 }
            ]
          }
        ]
      }
    },
    {
      "id": 15,
      "title": "Redis 쓰기 시간 통계",
      "type": "table",
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(redis_write_time_seconds_sum[1m])) / sum(rate(redis_write_time_seconds_count[1m]))",
          "format": "table",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "max(redis_write_time_seconds_max)",
          "format": "table",
          "instant": true
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.95, sum by(le) (rate(redis_write_time_seconds_bucket[1m])))",
          "format": "table",
          "instant": true
        },
        {
          "refId": "D",
          "expr": "histogram_quantile(0.99, sum by(le) (rate(redis_write_time_seconds_bucket[1m])))",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {
              "Value #A": 0,
              "Value #B": 1,
              "Value #C": 2,
              "Value #D": 3
            },
            "renameByName": {
              "Value #A": "mean",
              "Value #B": "max",
              "Value #C": "p95",
              "Value #D": "p99"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 4
        }
      }
    },
    {
      "id": 300,
      "title": "🚨 Errors & Reliability",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 }
    },
    {
      "id": 7,
      "title": "WebSocket 재연결",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "increase(websocket_reconnect_total[5m])",
          "legendFormat": "{{exchange}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 50
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max"]
        }
      }
    },
    {
      "id": 8,
      "title": "메시지 파싱 실패",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "rate(ticker_parse_failure_total[1m])",
          "legendFormat": "{{exchange}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 20
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max"]
        }
      }
    },
    {
      "id": 9,
      "title": "RabbitMQ NACK / Candle Flush 실패",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 27 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "increase(rabbitmq_nack_count_total[5m])",
          "legendFormat": "RabbitMQ NACK"
        },
        {
          "expr": "increase(candle_flush_failure_total[5m])",
          "legendFormat": "Candle Flush 실패"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 50
          }
        }
      }
    },
    {
      "id": 400,
      "title": "🏗 Infrastructure",
      "type": "row",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 }
    },
    {
      "id": 10,
      "title": "Candle Flush 소요 시간",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(candle_flush_duration_seconds_sum[1m]) / rate(candle_flush_duration_seconds_count[1m])",
          "legendFormat": "mean"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 16,
      "title": "Candle Flush 통계",
      "type": "table",
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 42 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(candle_flush_duration_seconds_sum[1m])) / sum(rate(candle_flush_duration_seconds_count[1m]))",
          "format": "table",
          "instant": true
        },
        {
          "refId": "B",
          "expr": "max(candle_flush_duration_seconds_max)",
          "format": "table",
          "instant": true
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.95, sum by(le) (rate(candle_flush_duration_seconds_bucket[1m])))",
          "format": "table",
          "instant": true
        },
        {
          "refId": "D",
          "expr": "histogram_quantile(0.99, sum by(le) (rate(candle_flush_duration_seconds_bucket[1m])))",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {
              "Value #A": 0,
              "Value #B": 1,
              "Value #C": 2,
              "Value #D": 3
            },
            "renameByName": {
              "Value #A": "mean",
              "Value #B": "max",
              "Value #C": "p95",
              "Value #D": "p99"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 4
        }
      }
    },
    {
      "id": 11,
      "title": "JVM Heap 사용량",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{area=\"heap\"}",
          "legendFormat": "used ({{id}})"
        },
        {
          "expr": "jvm_memory_max_bytes{area=\"heap\"}",
          "legendFormat": "max ({{id}})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "^max" },
            "properties": [
              { "id": "custom.lineStyle", "value": { "fill": "dash", "dash": [10, 10] } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          }
        ]
      }
    },
    {
      "id": 12,
      "title": "스레드풀 사용량",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 36 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "expr": "executor_pool_size{name=\"exchange.initializer\"}",
          "legendFormat": "pool size"
        },
        {
          "expr": "executor_active{name=\"exchange.initializer\"}",
          "legendFormat": "active"
        },
        {
          "expr": "rate(executor_completed_tasks_total{name=\"exchange.initializer\"}[1m])",
          "legendFormat": "completed/sec"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 1,
            "fillOpacity": 10
          }
        }
      }
    }
  ],
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      }
    ]
  },
  "schemaVersion": 39
}